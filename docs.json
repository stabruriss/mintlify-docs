{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Vibrant Wellness Portal API",
  "colors": {
    "primary": "#0F766E",
    "light": "#14B8A6",
    "dark": "#115E59"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "api-keys"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/orders",
              "concepts/reports",
              "concepts/test-catalog"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "guides/place-order",
              "guides/track-order",
              "guides/manage-orders",
              "guides/read-reports"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/errors",
              "platform/pagination",
              "platform/rate-limits",
              "platform/webhooks",
              "platform/environments"
            ]
          },
          {
            "group": "Coming soon",
            "pages": [
              "coming-soon/patients",
              "coming-soon/providers",
              "coming-soon/payment-methods"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Orders",
            "pages": [
              "api-reference/orders/create",
              "api-reference/orders/list",
              "api-reference/orders/get",
              "api-reference/orders/update",
              "api-reference/orders/cancel"
            ]
          },
          {
            "group": "Tracking",
            "pages": [
              "api-reference/tracking/get",
              "api-reference/tracking/events"
            ]
          },
          {
            "group": "Reports",
            "pages": [
              "api-reference/reports/list",
              "api-reference/reports/get",
              "api-reference/reports/download",
              "api-reference/reports/list-by-order"
            ]
          },
          {
            "group": "Test catalog",
            "pages": [
              "api-reference/tests/list"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/order-status-changed",
              "api-reference/webhooks/report-ready"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "href": "https://status.vibrant-wellness.example.com",
          "icon": "signal-bars"
        },
        {
          "anchor": "Changelog",
          "href": "https://developers.vibrant-wellness.example.com/changelog",
          "icon": "list-timeline"
        },
        {
          "anchor": "Support",
          "href": "mailto:portal-api@vibrant-wellness.example.com",
          "icon": "headset"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Portal",
        "href": "https://portal.vibrant-wellness.example.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://portal.vibrant-wellness.example.com/settings/api-keys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/vibrantwellness",
      "linkedin": "https://linkedin.com/company/vibrant-wellness"
    }
  }
}
